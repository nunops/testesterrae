<!DOCTYPE html>
<html lang="pt-PT">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Avaliação em 24h — Terraǝ</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght,SOFT@9..144,300..900,0..100&family=Instrument+Sans:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --cream: #F2EBDC;
    --cream-soft: #EDE5D3;
    --ink: #1F2820;
    --ink-soft: #2D3A30;
    --ink-deep: #161D17;
    --terracotta: #A04F2C;
    --terracotta-deep: #803D20;
    --sage: #7B8467;
    --sage-light: #9DA68A;
    --brown: #5A4A3A;
    --brown-light: #8A7866;
    --rule: #C9BFA8;
    --rule-soft: #D9D0BA;
    --rule-dark: rgba(242, 235, 220, 0.15);
    --paper: #F8F2E4;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }
  body {
    background: var(--cream);
    color: var(--ink);
    font-family: 'Instrument Sans', sans-serif;
    font-size: 16px;
    line-height: 1.55;
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
  }
  /* ---------- NAV ---------- */
  nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 22px 40px;
    border-bottom: 1px solid var(--rule);
    position: sticky;
    top: 0;
    background: rgba(242, 235, 220, 0.92);
    z-index: 100;
    backdrop-filter: blur(12px);
  }
  .wordmark {
    font-family: 'Fraunces', serif;
    font-weight: 400;
    font-size: 24px;
    letter-spacing: 0.02em;
    font-variation-settings: "SOFT" 50, "opsz" 144;
  }
  .nav-links { display: flex; gap: 32px; font-size: 14px; }
  .nav-links a {
    color: var(--ink);
    text-decoration: none;
    text-transform: uppercase;
    font-weight: 500;
    letter-spacing: 0.04em;
    transition: color 0.2s;
  }
  .nav-links a:hover { color: var(--terracotta); }
  .nav-links a.active { color: var(--terracotta); }
  .nav-phone {
    font-family: 'JetBrains Mono', monospace;
    font-size: 13px;
    color: var(--brown);
  }
  /* ---------- BREADCRUMB ---------- */
  .breadcrumb {
    padding: 28px 40px 0;
    font-size: 12px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--brown-light);
    font-family: 'JetBrains Mono', monospace;
    max-width: 1500px;
    margin: 0 auto;
  }
  .breadcrumb a { color: var(--brown-light); text-decoration: none; }
  .breadcrumb span { margin: 0 8px; opacity: 0.5; }
  /* ---------- HERO ---------- */
  .hero {
    padding: 60px 40px 100px;
    max-width: 1500px;
    margin: 0 auto;
  }
  .hero-stamp {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--terracotta);
    margin-bottom: 32px;
    display: inline-flex;
    align-items: center;
    gap: 14px;
  }
  .hero-stamp::before {
    content: '';
    width: 32px;
    height: 1px;
    background: var(--terracotta);
  }
  .hero-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 80px;
    align-items: end;
  }
  .hero-title {
    font-family: 'Fraunces', serif;
    font-weight: 300;
    font-variation-settings: "SOFT" 100, "opsz" 144;
    font-size: clamp(48px, 7vw, 110px);
    line-height: 0.96;
    letter-spacing: -0.025em;
    margin-bottom: 36px;
  }
  .hero-title em { font-style: italic; color: var(--terracotta); }
  .hero-deck {
    font-family: 'Fraunces', serif;
    font-weight: 300;
    font-style: italic;
    font-size: clamp(18px, 1.8vw, 22px);
    line-height: 1.5;
    color: var(--brown);
    max-width: 50ch;
    margin-bottom: 0;
  }
  .hero-stat {
    border-left: 1px solid var(--rule);
    padding-left: 32px;
  }
  .hero-stat-num {
    font-family: 'Fraunces', serif;
    font-weight: 300;
    font-size: 96px;
    line-height: 0.9;
    letter-spacing: -0.025em;
    color: var(--terracotta);
    margin-bottom: 16px;
  }
  .hero-stat-num small {
    font-family: 'Instrument Sans', sans-serif;
    font-weight: 400;
    font-size: 22px;
    color: var(--brown-light);
    letter-spacing: 0;
    margin-left: 6px;
  }
  .hero-stat-label {
    font-family: 'Fraunces', serif;
    font-style: italic;
    font-weight: 300;
    font-size: 17px;
    color: var(--ink-soft);
    line-height: 1.5;
    max-width: 30ch;
  }
  /* ---------- SECTION SHARED ---------- */
  section {
    padding: 100px 40px;
    max-width: 1500px;
    margin: 0 auto;
  }
  section.full {
    max-width: none;
    padding-left: 0;
    padding-right: 0;
  }
  .section-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--terracotta);
    display: inline-flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 24px;
  }
  .section-label::before {
    content: '';
    width: 24px;
    height: 1px;
    background: var(--terracotta);
  }
  .section-title {
    font-family: 'Fraunces', serif;
    font-weight: 300;
    font-size: clamp(36px, 5vw, 72px);
    line-height: 1;
    letter-spacing: -0.02em;
    margin-bottom: 24px;
    max-width: 18ch;
  }
  .section-title em { font-style: italic; color: var(--terracotta); }
  .section-deck {
    font-family: 'Fraunces', serif;
    font-style: italic;
    font-weight: 300;
    font-size: 19px;
    color: var(--brown);
    max-width: 60ch;
    margin-bottom: 56px;
  }
  /* ---------- COMPARISON TABLE ---------- */
  .comparison {
    background: var(--ink);
    color: var(--cream);
    padding: 100px 40px;
  }
  .comparison-inner {
    max-width: 1500px;
    margin: 0 auto;
  }
  .comparison-grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr 1fr 1.3fr;
    gap: 0;
    margin-top: 48px;
    border-top: 1px solid var(--rule-dark);
    border-bottom: 1px solid var(--rule-dark);
  }
  .comparison-cell {
    padding: 24px 24px;
    border-right: 1px solid var(--rule-dark);
    border-bottom: 1px solid var(--rule-dark);
    font-size: 14px;
  }
  .comparison-cell:nth-child(4n) { border-right: none; }
  .comparison-cell:nth-last-child(-n+4) { border-bottom: none; }
  .comparison-cell.head {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--cream);
    opacity: 0.5;
    padding: 16px 24px;
  }
  .comparison-cell.row-label {
    font-family: 'Fraunces', serif;
    font-weight: 400;
    font-size: 17px;
    color: var(--cream);
    background: rgba(242, 235, 220, 0.03);
  }
  .comparison-cell.terrae {
    background: rgba(160, 79, 44, 0.12);
    color: var(--cream);
  }
  .comparison-cell.head.terrae {
    background: var(--terracotta);
    color: var(--cream);
    opacity: 1;
  }
  .comparison-cell.muted {
    color: var(--cream);
    opacity: 0.65;
  }
  .check { color: #6FA85C; font-weight: 600; margin-right: 4px; }
  .cross { color: #C97D5E; font-weight: 600; margin-right: 4px; opacity: 0.8; }
  /* ---------- HOW IT WORKS ---------- */
  .how-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--rule);
    border: 1px solid var(--rule);
    margin-top: 56px;
  }
  .step {
    background: var(--cream);
    padding: 48px 40px;
    position: relative;
  }
  .step-num {
    font-family: 'Fraunces', serif;
    font-weight: 300;
    font-size: 56px;
    line-height: 1;
    color: var(--terracotta);
    margin-bottom: 24px;
    letter-spacing: -0.02em;
  }
  .step-time {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--brown);
    margin-bottom: 12px;
    display: inline-block;
    padding: 4px 10px;
    background: var(--paper);
    border-radius: 100px;
  }
  .step-title {
    font-family: 'Fraunces', serif;
    font-weight: 400;
    font-size: 26px;
    line-height: 1.2;
    margin-bottom: 16px;
    letter-spacing: -0.01em;
  }
  .step-desc {
    font-size: 15px;
    line-height: 1.6;
    color: var(--ink-soft);
    margin-bottom: 24px;
  }
  .step-list {
    list-style: none;
    border-top: 1px solid var(--rule);
    padding-top: 16px;
  }
  .step-list li {
    font-size: 13px;
    color: var(--brown);
    padding: 6px 0;
    display: flex;
    gap: 10px;
  }
  .step-list li::before {
    content: '—';
    color: var(--terracotta);
  }
  /* ---------- SAMPLE REPORT ---------- */
  .report-section { background: var(--paper); }
  .report-mockup {
    background: var(--cream);
    padding: 56px 64px;
    border: 1px solid var(--rule);
    margin-top: 48px;
    box-shadow: 0 30px 60px -30px rgba(31, 40, 32, 0.15);
    border-radius: 2px;
  }
  .report-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    border-bottom: 1px solid var(--rule);
    padding-bottom: 24px;
    margin-bottom: 32px;
    flex-wrap: wrap;
    gap: 16px;
  }
  .report-id {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--brown-light);
    margin-bottom: 8px;
  }
  .report-title {
    font-family: 'Fraunces', serif;
    font-weight: 400;
    font-size: 28px;
    line-height: 1.2;
    letter-spacing: -0.01em;
  }
  .report-tag {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--terracotta);
    background: var(--paper);
    padding: 6px 12px;
    border-radius: 100px;
  }
  /* Range / scenarios */
  .scenarios {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-bottom: 40px;
  }
  .scenario {
    padding: 24px;
    border: 1px solid var(--rule);
    border-radius: 3px;
    position: relative;
  }
  .scenario.recommended {
    border: 2px solid var(--terracotta);
    background: rgba(160, 79, 44, 0.04);
  }
  .scenario.recommended::before {
    content: '★ Recomendado';
    position: absolute;
    top: -10px;
    left: 16px;
    background: var(--terracotta);
    color: var(--cream);
    padding: 3px 10px;
    border-radius: 100px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .scenario-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--brown-light);
    margin-bottom: 8px;
  }
  .scenario-name {
    font-family: 'Fraunces', serif;
    font-weight: 400;
    font-size: 17px;
    margin-bottom: 16px;
    color: var(--ink);
  }
  .scenario-price {
    font-family: 'Fraunces', serif;
    font-weight: 300;
    font-size: 38px;
    line-height: 1;
    margin-bottom: 6px;
    color: var(--ink);
    letter-spacing: -0.015em;
  }
  .scenario-time {
    font-family: 'Fraunces', serif;
    font-style: italic;
    font-size: 14px;
    color: var(--brown);
    margin-bottom: 16px;
  }
  .scenario-bar {
    height: 4px;
    background: var(--rule-soft);
    border-radius: 100px;
    overflow: hidden;
    margin-bottom: 8px;
  }
  .scenario-bar-fill {
    height: 100%;
    background: var(--terracotta);
    border-radius: 100px;
  }
  .scenario-prob {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    color: var(--brown);
    letter-spacing: 0.04em;
  }
  /* Comparables */
  .report-section-title {
    font-family: 'Fraunces', serif;
    font-weight: 400;
    font-size: 18px;
    margin-bottom: 16px;
    letter-spacing: -0.005em;
    color: var(--ink);
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .report-section-title::before {
    content: '';
    width: 16px;
    height: 1px;
    background: var(--terracotta);
  }
  .comp-table { width: 100%; border-collapse: collapse; margin-bottom: 32px; }
  .comp-table th {
    text-align: left;
    padding: 10px 12px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--brown-light);
    border-bottom: 1px solid var(--rule);
    font-weight: 500;
  }
  .comp-table th.num, .comp-table td.num { text-align: right; }
  .comp-table td {
    padding: 12px 12px;
    border-bottom: 1px solid var(--rule-soft);
    font-size: 13px;
    color: var(--ink-soft);
  }
  .comp-table .addr {
    font-family: 'Fraunces', serif;
    font-weight: 400;
    color: var(--ink);
    font-size: 14px;
  }
  .comp-table .price {
    font-family: 'JetBrains Mono', monospace;
    font-weight: 500;
    color: var(--ink);
  }
  /* Recommendations */
  .recommendations {
    background: var(--paper);
    padding: 24px 28px;
    border-radius: 2px;
    border-left: 3px solid var(--terracotta);
    margin-bottom: 24px;
  }
  .recommendations ul { list-style: none; }
  .recommendations li {
    padding: 8px 0;
    display: flex;
    justify-content: space-between;
    gap: 16px;
    font-size: 14px;
    border-bottom: 1px solid var(--rule-soft);
  }
  .recommendations li:last-child { border-bottom: none; }
  .recommendations li .impact {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: var(--terracotta);
    flex-shrink: 0;
    font-weight: 500;
  }
  /* Buttons */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 14px 24px;
    border: 1px solid var(--ink);
    color: var(--ink);
    font-size: 13px;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    font-weight: 500;
    text-decoration: none;
    transition: all 0.2s;
    background: transparent;
    cursor: pointer;
    border-radius: 2px;
    font-family: 'Instrument Sans', sans-serif;
  }
  .btn::after {
    content: '→';
    font-family: 'JetBrains Mono', monospace;
    font-size: 14px;
  }
  .btn:hover { background: var(--ink); color: var(--cream); }
  .btn-primary { background: var(--ink); color: var(--cream); }
  .btn-primary:hover { background: var(--terracotta); border-color: var(--terracotta); }
  .btn-large { padding: 18px 32px; font-size: 14px; }
  .dark .btn { border-color: var(--cream); color: var(--cream); }
  .dark .btn:hover { background: var(--cream); color: var(--ink); }
  .dark .btn-primary { background: var(--terracotta); border-color: var(--terracotta); }
  /* ---------- FORM ---------- */
  .form-section {
    background: var(--ink);
    color: var(--cream);
    padding: 120px 40px;
  }
  .form-inner {
    max-width: 800px;
    margin: 0 auto;
  }
  .form-head {
    text-align: center;
    margin-bottom: 56px;
  }
  .form-title {
    font-family: 'Fraunces', serif;
    font-weight: 300;
    font-size: clamp(36px, 5vw, 64px);
    line-height: 1.05;
    letter-spacing: -0.02em;
    margin-bottom: 20px;
  }
  .form-title em { font-style: italic; color: var(--terracotta); }
  .form-deck {
    font-family: 'Fraunces', serif;
    font-style: italic;
    font-size: 18px;
    color: var(--cream);
    opacity: 0.75;
    max-width: 50ch;
    margin: 0 auto;
  }
  .stepper {
    display: flex;
    justify-content: space-between;
    margin-bottom: 48px;
    position: relative;
  }
  .stepper::before {
    content: '';
    position: absolute;
    top: 14px;
    left: 14px;
    right: 14px;
    height: 1px;
    background: var(--rule-dark);
    z-index: 0;
  }
  .step-dot {
    position: relative;
    z-index: 1;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: var(--ink);
    border: 1px solid var(--rule-dark);
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: var(--cream);
    opacity: 0.5;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s;
    cursor: pointer;
  }
  .step-dot.active {
    background: var(--terracotta);
    border-color: var(--terracotta);
    opacity: 1;
  }
  .step-dot.done {
    background: var(--terracotta);
    border-color: var(--terracotta);
    opacity: 1;
  }
  .step-dot.done::after { content: '✓'; }
  .step-dot.done span { display: none; }
  .form-card {
    background: rgba(242, 235, 220, 0.03);
    border: 1px solid var(--rule-dark);
    padding: 48px 56px;
    border-radius: 3px;
  }
  .form-step-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--terracotta);
    margin-bottom: 12px;
  }
  .form-step-title {
    font-family: 'Fraunces', serif;
    font-weight: 300;
    font-size: 32px;
    line-height: 1.15;
    margin-bottom: 32px;
    letter-spacing: -0.01em;
  }
  .form-step-title em { font-style: italic; color: var(--terracotta); }
  .field { margin-bottom: 24px; }
  .field label {
    display: block;
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--cream);
    opacity: 0.7;
    margin-bottom: 8px;
  }
  .field input, .field select {
    width: 100%;
    padding: 14px 16px;
    background: rgba(242, 235, 220, 0.05);
    border: 1px solid var(--rule-dark);
    color: var(--cream);
    font-family: 'Instrument Sans', sans-serif;
    font-size: 15px;
    border-radius: 2px;
  }
  .field input:focus, .field select:focus {
    outline: none;
    border-color: var(--terracotta);
    background: rgba(160, 79, 44, 0.08);
  }
  .field input::placeholder { color: rgba(242, 235, 220, 0.4); }
  .row-2 {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }
  /* Type chips */
  .chips {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }
  .chip {
    padding: 12px 20px;
    border: 1px solid var(--rule-dark);
    background: rgba(242, 235, 220, 0.03);
    color: var(--cream);
    font-size: 14px;
    border-radius: 100px;
    cursor: pointer;
    transition: all 0.2s;
    font-family: 'Instrument Sans', sans-serif;
  }
  .chip:hover { border-color: var(--terracotta); }
  .chip.selected {
    background: var(--terracotta);
    border-color: var(--terracotta);
  }
  .form-actions {
    display: flex;
    justify-content: space-between;
    margin-top: 32px;
    gap: 12px;
  }
  .btn-back {
    background: transparent;
    border: 1px solid var(--rule-dark);
    color: var(--cream);
  }
  .btn-back::after { content: '←'; order: -1; }
  .btn-back:hover { background: rgba(242, 235, 220, 0.05); border-color: var(--cream); }
  /* Privacy note */
  .privacy {
    text-align: center;
    margin-top: 32px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: var(--cream);
    opacity: 0.5;
    letter-spacing: 0.05em;
  }
  /* ---------- TESTIMONIAL ---------- */
  .testimonial {
    padding: 120px 40px;
    max-width: 1200px;
    margin: 0 auto;
  }
  .testimonial-grid {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: 80px;
    align-items: center;
  }
  .test-image {
    width: 100%;
    aspect-ratio: 4/5;
    background-image: url('https://images.unsplash.com/photo-1582407947304-fd86f028f716?w=1200&q=85');
    background-size: cover;
    background-position: center;
    border-radius: 2px;
  }
  .test-quote-mark {
    font-family: 'Fraunces', serif;
    font-style: italic;
    font-size: 80px;
    color: var(--terracotta);
    line-height: 0.5;
    margin-bottom: 16px;
  }
  .test-quote {
    font-family: 'Fraunces', serif;
    font-weight: 300;
